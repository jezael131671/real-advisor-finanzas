VITE_FINNHUB_API_KEY=
# Finnhub free tier: https://finnhub.io (60 calls/min, no CC required)
# Provides: stocks, ETFs, FX — real-time price, change$, change%, dayHigh, dayLow

# Legacy fallback (still works if VITE_FINNHUB_API_KEY is empty)
VITE_MARKET_API_KEY=

# ── IBKR Client Portal Gateway ───────────────────────────────────────────────
# Setup (one-time per session):
#   1. Download Client Portal Gateway from IBKR
#   2. Run: bin\run.bat root\conf.yaml  (Windows)
#            ./bin/run.sh root/conf.yaml (macOS/Linux)
#   3. Open https://localhost:5000 in browser → accept self-signed cert → log in
#   4. The Vite dev server proxies /v1/api/* to localhost:5000 automatically
#      (no manual cert acceptance needed in the app during development)
#
# 'mock' mode (default): uses synthetic data — no gateway required.
# 'real' mode: connects to your live IBKR account via the local gateway.
VITE_IBKR_MODE=mock
VITE_IBKR_GATEWAY_URL=https://localhost:5000
VITE_IBKR_ACCOUNT_ID=             # optional — auto-detected from gateway session
